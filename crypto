#!/usr/bin/env python3
"""
Täglicher Krypto-E-Mail-Report
Abrufen von Kursdaten via CoinGecko und Versand per Gmail SMTP.

Cron-Job (täglich 08:00 Uhr):
    0 8 * * * /usr/bin/python3 /pfad/zu/crypto_report.py
"""

import os
import smtplib
from datetime import datetime
from email.mime.multipart import MIMEMultipart
from email.mime.text import MIMEText

import requests
from dotenv import load_dotenv

load_dotenv()

SMTP_HOST = os.environ["SMTP_HOST"]
SMTP_PORT = int(os.environ["SMTP_PORT"])
SMTP_USER = os.environ["SMTP_USER"]
SMTP_PASSWORD = os.environ["SMTP_PASSWORD"]
RECIPIENT_EMAIL = os.environ["RECIPIENT_EMAIL"]
COINS = [c.strip() for c in os.environ.get("COINS", "bitcoin,ethereum").split(",")]
CURRENCY = os.environ.get("CURRENCY", "eur").lower()

CURRENCY_SYMBOL = {"eur": "€", "usd": "$", "gbp": "£"}.get(CURRENCY, CURRENCY.upper())


def fetch_crypto_data() -> list[dict]:
    url = "https://api.coingecko.com/api/v3/coins/markets"
    params = {
        "vs_currency": CURRENCY,
        "ids": ",".join(COINS),
        "order": "market_cap_desc",
        "sparkline": "false",
        "price_change_percentage": "24h",
    }
    response = requests.get(url, params=params, timeout=15)
    response.raise_for_status()
    return response.json()


def format_number(value: float, decimals: int = 2) -> str:
    if value is None:
        return "N/A"
    if abs(value) >= 1_000_000_000:
        return f"{value / 1_000_000_000:.2f} Mrd."
    if abs(value) >= 1_000_000:
        return f"{value / 1_000_000:.2f} Mio."
    return f"{value:,.{decimals}f}".replace(",", "X").replace(".", ",").replace("X", ".")


def build_html_report(data: list[dict]) -> str:
    today = datetime.now().strftime("%d.%m.%Y %H:%M Uhr")

    rows = ""
    for coin in data:
        change = coin.get("price_change_percentage_24h")
        if change is None:
            change_str = "N/A"
            color = "#888888"
            arrow = ""
        elif change >= 0:
            change_str = f"+{change:.2f}%"
            color = "#16a34a"
            arrow = "▲"
        else:
            change_str = f"{change:.2f}%"
            color = "#dc2626"
            arrow = "▼"

        price = coin.get("current_price")
        price_decimals = 6 if price is not None and price < 1 else 2
        price_str = f"{CURRENCY_SYMBOL} {format_number(price, price_decimals)}" if price is not None else "N/A"

        market_cap = coin.get("market_cap")
        volume = coin.get("total_volume")

        rows += f"""
        <tr>
          <td style="padding:10px 14px; border-bottom:1px solid #e5e7eb;">
            <img src="{coin.get('image', '')}" width="24" height="24"
                 style="vertical-align:middle; margin-right:8px; border-radius:50%;">
            <strong>{coin.get('name', '')}</strong>
            <span style="color:#6b7280; font-size:12px; margin-left:4px;">{coin.get('symbol', '').upper()}</span>
          </td>
          <td style="padding:10px 14px; border-bottom:1px solid #e5e7eb; text-align:right; font-weight:600;">
            {price_str}
          </td>
          <td style="padding:10px 14px; border-bottom:1px solid #e5e7eb; text-align:right;
                     color:{color}; font-weight:600;">
            {arrow} {change_str}
          </td>
          <td style="padding:10px 14px; border-bottom:1px solid #e5e7eb; text-align:right; color:#374151;">
            {CURRENCY_SYMBOL} {format_number(market_cap)}
          </td>
          <td style="padding:10px 14px; border-bottom:1px solid #e5e7eb; text-align:right; color:#374151;">
            {CURRENCY_SYMBOL} {format_number(volume)}
          </td>
        </tr>"""

    html = f"""<!DOCTYPE html>
<html lang="de">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"></head>
<body style="margin:0; padding:0; background:#f3f4f6; font-family: Arial, sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f3f4f6; padding:30px 0;">
    <tr><td align="center">
      <table width="640" cellpadding="0" cellspacing="0"
             style="background:#ffffff; border-radius:12px; overflow:hidden;
                    box-shadow:0 2px 12px rgba(0,0,0,0.08);">
        <tr>
          <td style="background:linear-gradient(135deg,#1e3a5f,#2563eb);
                     padding:28px 32px; text-align:center;">
            <h1 style="margin:0; color:#ffffff; font-size:24px; letter-spacing:0.5px;">
              📈 Täglicher Krypto-Report
            </h1>
            <p style="margin:6px 0 0; color:#bfdbfe; font-size:14px;">{today}</p>
          </td>
        </tr>
        <tr>
          <td style="padding:24px 32px;">
            <table width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
              <thead>
                <tr style="background:#f8fafc;">
                  <th style="padding:10px 14px; text-align:left; font-size:13px; color:#6b7280; border-bottom:2px solid #e5e7eb;">Coin</th>
                  <th style="padding:10px 14px; text-align:right; font-size:13px; color:#6b7280; border-bottom:2px solid #e5e7eb;">Kurs</th>
                  <th style="padding:10px 14px; text-align:right; font-size:13px; color:#6b7280; border-bottom:2px solid #e5e7eb;">24h</th>
                  <th style="padding:10px 14px; text-align:right; font-size:13px; color:#6b7280; border-bottom:2px solid #e5e7eb;">Marktkapitalisierung</th>
                  <th style="padding:10px 14px; text-align:right; font-size:13px; color:#6b7280; border-bottom:2px solid #e5e7eb;">Volumen (24h)</th>
                </tr>
              </thead>
              <tbody>{rows}
              </tbody>
            </table>
          </td>
        </tr>
        <tr>
          <td style="padding:16px 32px 24px; text-align:center; border-top:1px solid #e5e7eb; color:#9ca3af; font-size:12px;">
            Daten: CoinGecko API &nbsp;|&nbsp; Währung: {CURRENCY.upper()} &nbsp;|&nbsp; Kein Anlageberatung – nur zur Information.
          </td>
        </tr>
      </table>
    </td></tr>
  </table>
</body>
</html>"""
    return html


def send_email(subject: str, html_body: str) -> None:
    msg = MIMEMultipart("alternative")
    msg["Subject"] = subject
    msg["From"] = SMTP_USER
    msg["To"] = RECIPIENT_EMAIL
    msg.attach(MIMEText(html_body, "html", "utf-8"))

    with smtplib.SMTP(SMTP_HOST, SMTP_PORT) as server:
        server.ehlo()
        server.starttls()
        server.login(SMTP_USER, SMTP_PASSWORD)
        server.sendmail(SMTP_USER, RECIPIENT_EMAIL, msg.as_string())


def main() -> None:
    print(f"[{datetime.now().strftime('%H:%M:%S')}] Rufe Kryptodaten ab ...")
    try:
        data = fetch_crypto_data()
    except requests.RequestException as e:
        print(f"Fehler beim Abrufen der Kryptodaten: {e}")
        raise SystemExit(1)

    if not data:
        print("Keine Daten von der API erhalten. Bitte Coin-IDs prüfen.")
        raise SystemExit(1)

    print(f"[{datetime.now().strftime('%H:%M:%S')}] {len(data)} Coins geladen. Erstelle Report ...")
    html = build_html_report(data)

    date_str = datetime.now().strftime("%d.%m.%Y")
    subject = f"📈 Krypto-Report {date_str}"

    print(f"[{datetime.now().strftime('%H:%M:%S')}] Sende E-Mail an {RECIPIENT_EMAIL} ...")
    try:
        send_email(subject, html)
    except smtplib.SMTPException as e:
        print(f"Fehler beim E-Mail-Versand: {e}")
        raise SystemExit(1)

    print(f"[{datetime.now().strftime('%H:%M:%S')}] E-Mail erfolgreich versendet.")


if __name__ == "__main__":
    main()
